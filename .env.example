# API Configuration
TOKEN=your_token_here

# Provider: opencode-go, openrouter, villamarket, moonshot, huggingface, custom
PROVIDER=opencode-go

# Model (optional - overrides provider default)
# Default for opencode-go: minimax-m2.7
MODEL=

# Base URL (optional - overrides provider default)
# Default for opencode-go: https://opencode.ai/zen/go/v1
BASE_URL=

# Optional: Custom fallback models (format: model_name|base_url,...)
# Example: FALLBACK_MODELS=minimax/minimax-max|https://openrouter.ai/api/v1,Qwen/Qwen3-Coder-Next|https://router.huggingface.co/v1
# Defaults to empty (no fallbacks unless configured)

# Optional: Tavily API key for web search
# Get free key at https://tavily.com/api (1000 queries/month free)
# TAVILY_API_KEY=

# Max tokens per response (recommended: 16000-32000 for development)
MAX_TOKENS=32000

# Max iterations per conversation (default: 50 for complex projects)
MAX_ITERATIONS=100

# Auto-plan threshold (default: 4)
PLAN_AUTO_THRESHOLD=4

# Max retries for failed builds (default: 5)
MAX_RETRIES=5

# Timezone (default: America/Sao_Paulo)
TZ=America/Sao_Paulo

# ===========================================
# Heartbeat Configuration
# ===========================================
# Enable heartbeat messages (default: true)
HEARTBEAT_ENABLED=true

# Hour to send heartbeat (default: 8)
HEARTBEAT_HOUR=8

# Minute to send heartbeat (default: 0)
HEARTBEAT_MINUTE=0

# ===========================================
# Browser Automation
# ===========================================
# Chrome/Chromium path (auto-detected if not set)
# CHROME_PATH=/usr/bin/chromium-browser

# Screenshot max width (default: 1920)
SCREENSHOT_MAX_WIDTH=1920

# Screenshot quality 0-100 (default: 85)
SCREENSHOT_QUALITY=85

# ===========================================
# Agent Loop Configuration
# ===========================================
# Auto-retry failed steps (default: true)
AGENT_AUTO_RETRY=true

# Max retries per failed step (default: 3)
AGENT_MAX_RETRIES_PER_STEP=3

# Require build validation before continuing (default: true)
AGENT_VALIDATION_REQUIRED=true

# Exit behavior on max retries: task, session, never (default: task)
AGENT_EXIT_ON_ERROR=task

# Force tool use for development tasks (default: true)
AGENT_FORCE_TOOL_USE=true

# ===========================================
# Self-Review Configuration
# ===========================================
# Enable self-review loop (default: true)
SELF_REVIEW_ENABLED=true

# Max self-review loops (default: 3)
SELF_REVIEW_MAX_LOOPS=3

# Show self-review process to user (default: true)
SELF_REVIEW_SHOW_PROCESS=true

# ===========================================
# Feature Flags (set to 1 or true to enable)
# ===========================================
# VOICE_MODE=1          # Voice input mode
# PROACTIVE=1           # Proactive mode
# BRIDGE_MODE=1         # IDE bridge mode
# DAEMON=1              # Daemon mode
# AGENT_TRIGGERS=1      # Agent triggers
# MONITOR_TOOL=1        # Tool monitoring
# DEBUG=1               # Debug mode
# VERBOSE=1             # Verbose logging
