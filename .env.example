# API Configuration
OPENCODE_API_KEY=your_api_key_here

# Provider: opencode-go, openrouter, villamarket, moonshot, huggingface
PROVIDER=opencode-go

# Optional: Custom fallback models (format: model_name|base_url,...)
# Example: FALLBACK_MODELS=minimax/minimax-m2.5:free|https://openrouter.ai/api/v1,Qwen/Qwen3-Coder-Next|https://router.huggingface.co/v1
# Defaults to OpenRouter and HuggingFace if not specified

# Optional: Tavily API key for web search
TAVILY_API_KEY=your_tavily_key_here

# Max tokens per response (default: 4000)
MAX_TOKENS=4000

# Max iterations per conversation (default: 20)
MAX_ITERATIONS=20

# Auto-plan threshold (default: 4)
PLAN_AUTO_THRESHOLD=4

# Max retries for failed builds (default: 5)
MAX_RETRIES=5

# Timezone (default: America/Sao_Paulo)
TZ=America/Sao_Paulo

# Feature Flags (set to 1 or true to enable)
# VOICE_MODE=1          # Voice input mode
# PROACTIVE=1          # Proactive mode
# BRIDGE_MODE=1        # IDE bridge mode
# DAEMON=1             # Daemon mode
# AGENT_TRIGGERS=1     # Agent triggers
# MONITOR_TOOL=1       # Tool monitoring
# DEBUG=1              # Debug mode
# VERBOSE=1            # Verbose logging
