# Hugging Face Token (Get yours at: https://huggingface.co/settings/tokens)
# Required permission: Read
# Model: deepseek-ai/DeepSeek-V3 (671B parameters, MoE, 128K context)
# Free tier: ~1000 requests/day | PRO ($9/month): Unlimited + faster
# First request may take 30-60s (cold start), subsequent requests faster
HUGGINGFACE_TOKEN=

# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=

# Optional: Restrict bot to specific chat ID (get from @userinfobot)
# If not set, bot accepts messages from anyone
TELEGRAM_CHAT_ID=

# Timezone for scheduled tasks (default: UTC)
# Examples: America/Sao_Paulo, America/New_York, Europe/London
TZ=America/Sao_Paulo

# Max tokens for model responses (default: 1200)
MAX_TOKENS=1200

# Heartbeat configuration
HEARTBEAT_ENABLED=true
HEARTBEAT_HOUR=8
HEARTBEAT_MINUTE=0

# Browser Automation (Fase 6)
# Chrome/Chromium path (auto-detected if not set)
# CHROME_PATH=/usr/bin/chromium-browser
# 
# Screenshot settings
SCREENSHOT_MAX_WIDTH=1920
SCREENSHOT_QUALITY=85

TAVILY_API_KEY=

# TMUX Configuration (for real-time visualization)
# Enable TMUX sessions for real-time visualization
TMUX_ENABLED=false

# Log level: debug, info, warn, error
LOG_LEVEL=debug
